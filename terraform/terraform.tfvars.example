# Copy to terraform.tfvars (gitignored) and fill in real values.
# NEVER commit terraform.tfvars -- it is covered by .gitignore.

# --- Confluent Cloud control-plane API key ---
# Create at: https://confluent.cloud/settings/api-keys  (scope: "Cloud resource management")
confluent_cloud_api_key    = "REPLACE_WITH_CONFLUENT_CLOUD_API_KEY"
confluent_cloud_api_secret = "REPLACE_WITH_CONFLUENT_CLOUD_API_SECRET"

# --- Cloud / region (must be a region where Confluent Flink is available) ---
cloud_provider   = "AWS"
region           = "us-east-1"
environment_name = "gpu-efficiency-demo"

# --- Amazon S3 Sink (committed core sink) ---
aws_access_key_id     = "REPLACE_WITH_AWS_ACCESS_KEY_ID"
aws_secret_access_key = "REPLACE_WITH_AWS_SECRET_ACCESS_KEY"
s3_bucket_name        = "your-gpu-efficiency-lake-bucket"
aws_region            = "us-east-1"

# --- Optional: HTTP Sink (anomaly alerts to a webhook) ---
enable_http_sink  = false
alert_webhook_url = ""

# --- Optional: Datadog Metrics Sink (efficiency observability) ---
enable_datadog_sink = false
datadog_api_key     = ""
datadog_site        = "US"
