{
  "type": "record",
  "name": "GpuInferenceTelemetry",
  "namespace": "io.lutflow.demo.v1",
  "doc": "Datagen Source generator definition. Mirrors schemas/gpu_telemetry.avsc, with Avro Random Generator arg.properties to produce plausible synthetic telemetry. The gpu_util_pct distribution is intentionally bimodal (mostly busy, occasionally idle) so that ML_DETECT_ANOMALIES has clear idle-waste anomalies to flag.",
  "fields": [
    {"name": "deployment_id", "type": {"type": "string", "arg.properties": {"options": ["inference-node-a"]}}},
    {"name": "model_id", "type": {"type": "string", "arg.properties": {"options": ["granite-3.3-8b-instruct"]}}},
    {"name": "gpu_uuid", "type": {"type": "string", "arg.properties": {"options": ["GPU-0a1b2c3d", "GPU-4e5f6a7b", "GPU-8c9d0e1f", "GPU-2f3a4b5c"]}}},
    {"name": "gpu_model", "type": {"type": "string", "arg.properties": {"options": ["NVIDIA L4"]}}},
    {"name": "ts", "type": {"type": "long", "arg.properties": {"iteration": {"start": 1700000000000, "step": 1000}}}},

    {"name": "gpu_util_pct", "type": {"type": "double", "arg.properties": {"options": [4.0, 6.0, 8.0, 88.0, 90.0, 92.0, 95.0, 97.0, 99.0, 99.0, 99.0]}}},
    {"name": "sm_active_ratio", "type": {"type": "double", "arg.properties": {"range": {"min": 0.0, "max": 1.0}}}},
    {"name": "tensor_active_ratio", "type": {"type": "double", "arg.properties": {"range": {"min": 0.0, "max": 1.0}}}},
    {"name": "dram_active_ratio", "type": {"type": "double", "arg.properties": {"range": {"min": 0.0, "max": 1.0}}}},
    {"name": "fb_used_mib", "type": {"type": "double", "arg.properties": {"range": {"min": 2000.0, "max": 23000.0}}}},
    {"name": "power_watts", "type": {"type": "double", "arg.properties": {"range": {"min": 38.0, "max": 72.0}}}},
    {"name": "energy_mj", "type": {"type": "long", "arg.properties": {"iteration": {"start": 0, "step": 4200}}}},
    {"name": "temp_celsius", "type": {"type": "double", "arg.properties": {"range": {"min": 40.0, "max": 84.0}}}},

    {"name": "num_requests_running", "type": {"type": "int", "arg.properties": {"range": {"min": 0, "max": 256}}}},
    {"name": "num_requests_waiting", "type": {"type": "int", "arg.properties": {"range": {"min": 0, "max": 300}}}},
    {"name": "kv_cache_usage_perc", "type": {"type": "double", "arg.properties": {"range": {"min": 0.0, "max": 1.0}}}},
    {"name": "prompt_tokens_total", "type": {"type": "long", "arg.properties": {"iteration": {"start": 0, "step": 1200}}}},
    {"name": "generation_tokens_total", "type": {"type": "long", "arg.properties": {"iteration": {"start": 0, "step": 800}}}},
    {"name": "ttft_seconds", "type": {"type": "double", "arg.properties": {"range": {"min": 0.05, "max": 12.0}}}},
    {"name": "inter_token_latency_s", "type": {"type": "double", "arg.properties": {"range": {"min": 0.005, "max": 0.08}}}},
    {"name": "e2e_latency_seconds", "type": {"type": "double", "arg.properties": {"range": {"min": 0.2, "max": 60.0}}}}
  ]
}
